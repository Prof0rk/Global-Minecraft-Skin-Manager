{
  "name": "global-minecraft-skin-manager",
  "version": "1.0.1",
  "description": "Premium Minecraft skin manager with liquid glass pixel white UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "pack:linux": "electron-builder --linux AppImage",
    "pack:win": "electron-builder --windows portable",
    "pack:all": "electron-builder --linux AppImage --windows portable"
  },
  "keywords": [
    "minecraft",
    "skin-manager",
    "oauth",
    "electron"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.d0ktorek.global-minecraft-skin-manager",
    "productName": "Global Minecraft Skin Manager",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "public/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "directories": {
      "output": "dist"
    }
  }
}
